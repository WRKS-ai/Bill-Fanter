<script is:inline>
(function(){
  var bgs=document.querySelectorAll('.blas3-sc-bg'),panels=document.querySelectorAll('.blas3-sc-panel'),dots=document.querySelectorAll('.blas3-sc-dot');
  if(!bgs.length)return;
  var cur=0,n=bgs.length,INTERVAL=4800,buildT=[],launchT=[],adaptT=[],scaleTs=[],scaleR,scaleT;
  function startBuild(){document.querySelectorAll('#bm-build .bm-svc').forEach(function(el,i){buildT.push(setTimeout(function(){el.classList.add('in');},i*160+150));});}
  function resetBuild(){buildT.forEach(clearTimeout);buildT=[];document.querySelectorAll('#bm-build .bm-svc').forEach(function(el){el.classList.remove('in');});}
  function startLaunch(){var rows=document.querySelectorAll('#bm-launch .bm-deploy-row'),countEl=document.getElementById('bm-deploy-cnt'),fillEl=document.getElementById('bm-deploy-fill'),total=rows.length;rows.forEach(function(row,i){launchT.push(setTimeout(function(){row.classList.add('in');if(countEl)countEl.textContent=(i+1)+' / '+total;if(fillEl)fillEl.style.width=((i+1)/total*100)+'%';},i*370+180));});}
  function resetLaunch(){launchT.forEach(clearTimeout);launchT=[];document.querySelectorAll('#bm-launch .bm-deploy-row').forEach(function(r){r.classList.remove('in');});var c=document.getElementById('bm-deploy-cnt'),f=document.getElementById('bm-deploy-fill');if(c)c.textContent='0 / 6';if(f)f.style.width='0%';}
  function startAdapt(){document.querySelectorAll('#bm-adapt .bm-metric-card').forEach(function(card,i){var d=i*250+150;adaptT.push(setTimeout(function(){card.classList.add('in');var bf=card.querySelector('.bm-metric-bar-fill');if(bf)bf.style.width=bf.dataset.width+'%';var ve=card.querySelector('.bm-metric-val');if(ve){var tgt=+ve.dataset.target,prefix=ve.dataset.prefix||'',suffix=ve.dataset.suffix||'',dec=+(ve.dataset.dec||0),s=performance.now(),dur=1200;function tick(now){var t=Math.min((now-s)/dur,1),ease=1-Math.pow(1-t,3);ve.textContent=prefix+(ease*tgt).toFixed(dec)+suffix;if(t<1)requestAnimationFrame(tick);}requestAnimationFrame(tick);}},d));adaptT.push(setTimeout(function(){var p=card.querySelector('.bm-status-pill');if(p)p.classList.add('in');},d+1350));});}
  function resetAdapt(){adaptT.forEach(clearTimeout);adaptT=[];document.querySelectorAll('#bm-adapt .bm-metric-card').forEach(function(c){c.classList.remove('in');});document.querySelectorAll('#bm-adapt .bm-metric-bar-fill').forEach(function(f){f.style.width='0%';});document.querySelectorAll('#bm-adapt .bm-metric-val').forEach(function(el){el.textContent=(el.dataset.prefix||'')+(0).toFixed(+(el.dataset.dec||0))+(el.dataset.suffix||'');});document.querySelectorAll('#bm-adapt .bm-status-pill').forEach(function(p){p.classList.remove('in');});}
  function startScale(){var path=document.getElementById('bm-sv3-line');if(path){var len=path.getTotalLength();path.style.strokeDasharray=len;path.style.strokeDashoffset=len;path.style.transition='none';scaleT=setTimeout(function(){path.style.transition='stroke-dashoffset 2.2s cubic-bezier(.16,1,.3,1)';path.style.strokeDashoffset='0';},80);}var valEl=document.querySelector('#bm-scale .bm-sv3-val'),dltEl=document.querySelector('#bm-scale .bm-sv3-delta'),s=performance.now(),dur=2400,tgt=284700;function tick(now){var t=Math.min((now-s)/dur,1),ease=1-Math.pow(1-t,3);if(valEl)valEl.textContent='$'+Math.round(ease*tgt).toLocaleString();if(dltEl)dltEl.textContent='+'+Math.round(ease*312)+'%';if(t<1)scaleR=requestAnimationFrame(tick);}scaleR=requestAnimationFrame(tick);document.querySelectorAll('#bm-scale .bm-sv3-row').forEach(function(row,i){scaleTs.push(setTimeout(function(){row.classList.add('in');var fill=row.querySelector('.bm-sv3-fill');if(fill)fill.style.width=fill.dataset.width+'%';},i*240+750));});}
  function resetScale(){cancelAnimationFrame(scaleR);clearTimeout(scaleT);scaleTs.forEach(clearTimeout);scaleTs=[];var path=document.getElementById('bm-sv3-line');if(path){var len=path.getTotalLength();path.style.transition='none';path.style.strokeDasharray=len;path.style.strokeDashoffset=len;}var v=document.querySelector('#bm-scale .bm-sv3-val'),d=document.querySelector('#bm-scale .bm-sv3-delta');if(v)v.textContent='$0';if(d)d.textContent='+0%';document.querySelectorAll('#bm-scale .bm-sv3-row').forEach(function(row){row.classList.remove('in');var fill=row.querySelector('.bm-sv3-fill');if(fill)fill.style.width='0%';});}
  var animStart=[startBuild,startLaunch,startAdapt,startScale],animReset=[resetBuild,resetLaunch,resetAdapt,resetScale];
  var mtabs=document.querySelectorAll('.bmt'),bcols=document.querySelectorAll('.blas3-col');
  function goTo(i){animReset[cur]();bgs[cur].classList.remove('active');panels[cur].classList.remove('active');dots[cur].classList.remove('active');if(mtabs[cur])mtabs[cur].classList.remove('active');if(bcols[cur])bcols[cur].classList.remove('active');cur=i;bgs[cur].classList.add('active');panels[cur].classList.add('active');dots[cur].classList.add('active');if(mtabs[cur])mtabs[cur].classList.add('active');if(bcols[cur])bcols[cur].classList.add('active');animStart[cur]();}
  function restartTimer(){clearInterval(timer);timer=setInterval(function(){goTo((cur+1)%n);},INTERVAL);}
  var timer=setInterval(function(){goTo((cur+1)%n);},INTERVAL);
  dots.forEach(function(d,i){d.addEventListener('click',function(){restartTimer();goTo(i);});});
  mtabs.forEach(function(btn,i){btn.addEventListener('click',function(){restartTimer();goTo(i);});});
  bcols.forEach(function(col,i){col.addEventListener('mouseenter',function(){restartTimer();goTo(i);});});
  if(bcols[0])bcols[0].classList.add('active');
  var showcase=document.querySelector('.blas3-showcase'),txStart=0;
  if(showcase){showcase.addEventListener('touchstart',function(e){txStart=e.touches[0].clientX;},{passive:true});showcase.addEventListener('touchend',function(e){var dx=e.changedTouches[0].clientX-txStart;if(Math.abs(dx)>40){restartTimer();goTo(dx<0?(cur+1)%n:(cur-1+n)%n);}},{passive:true});}
  startBuild();
})();
</script>

<script is:inline define:vars={{ calendarAudience: data.calendarAudience }}>
(function(){
  var p = new URLSearchParams(window.location.search);
  var name     = p.get('name')  || '';
  var startISO = p.get('start') || '';
  var endISO   = p.get('end')   || '';
  var loc      = p.get('loc')   || 'Zoom';
  var tz       = p.get('tz')    || '';

  if (name) {
    var firstName = name.split(' ')[0];
    var nameEl = document.getElementById('js-vid-name');
    if (nameEl) nameEl.textContent = ' ' + firstName;
  }

  if (startISO) {
    var startDate = new Date(startISO);
    var endDate   = endISO ? new Date(endISO) : new Date(startDate.getTime() + 45 * 60 * 1000);

    var dateOpts = { weekday:'long', month:'long', day:'numeric' };
    var timeOpts = { hour:'numeric', minute:'2-digit' };
    var tzOpts   = { timeZoneName:'short' };
    if (tz) { dateOpts.timeZone = tz; timeOpts.timeZone = tz; tzOpts.timeZone = tz; }

    var dateStr = startDate.toLocaleDateString('en-US', dateOpts);
    var timeStr = startDate.toLocaleTimeString('en-US', timeOpts);
    var tzStr   = startDate.toLocaleTimeString('en-US', tzOpts).split(' ').pop();

    var dateEl = document.getElementById('js-call-date');
    var timeEl = document.getElementById('js-call-time');
    if (dateEl) dateEl.textContent = dateStr;
    if (timeEl) timeEl.textContent = timeStr + ' ' + tzStr;

    var wrap = document.getElementById('call-time-wrap');
    var fallback = document.getElementById('call-time-fallback');
    if (wrap) wrap.style.display = '';
    if (fallback) fallback.style.display = 'none';

    // Countdown
    var cdEl = document.getElementById('js-countdown');
    function tick(){
      var diff = startDate.getTime() - Date.now();
      if (!cdEl) return;
      if (diff <= 0) { cdEl.textContent = 'Live now'; return; }
      var d = Math.floor(diff/86400000);
      var h = Math.floor((diff%86400000)/3600000);
      var m = Math.floor((diff%3600000)/60000);
      var s = Math.floor((diff%60000)/1000);
      var parts = [];
      if (d) parts.push(d + 'd');
      if (h || d) parts.push(h + 'h');
      parts.push(m + 'm');
      parts.push(s + 's');
      cdEl.textContent = parts.join(' ');
    }
    tick(); setInterval(tick, 1000);

    function toCalDate(d) {
      return d.toISOString().replace(/[-:]/g,'').replace(/\.\d{3}/,'');
    }
    var s = toCalDate(startDate), e = toCalDate(endDate);
    var title   = 'Discovery Call with WRKS Online';
    var details = 'Come prepared with ' + calendarAudience + ' goals and questions.' + (loc ? ' Join here: ' + loc : '');

    var gcalUrl = 'https://calendar.google.com/calendar/render?action=TEMPLATE'
      + '&text='     + encodeURIComponent(title)
      + '&dates='    + s + '/' + e
      + '&details='  + encodeURIComponent(details)
      + '&location=' + encodeURIComponent(loc);
    var gcalLink = document.getElementById('gcal-link');
    if (gcalLink) gcalLink.href = gcalUrl;

    var outlookUrl = 'https://outlook.live.com/calendar/0/deeplink/compose'
      + '?path=/calendar/action/compose&rru=addevent'
      + '&subject='  + encodeURIComponent(title)
      + '&startdt='  + encodeURIComponent(startDate.toISOString())
      + '&enddt='    + encodeURIComponent(endDate.toISOString())
      + '&body='     + encodeURIComponent(details)
      + '&location=' + encodeURIComponent(loc);
    var outlookLink = document.getElementById('outlook-link');
    if (outlookLink) outlookLink.href = outlookUrl;

    var ics = [
      'BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//WRKS Online//EN',
      'BEGIN:VEVENT',
      'DTSTART:'     + s,
      'DTEND:'       + e,
      'SUMMARY:'     + title,
      'DESCRIPTION:' + details.replace(/,/g,'\\,'),
      'LOCATION:'    + loc,
      'END:VEVENT', 'END:VCALENDAR'
    ].join('\r\n');
    var icalLink = document.getElementById('ical-link');
    if (icalLink) icalLink.href = 'data:text/calendar;charset=utf8,' + encodeURIComponent(ics);

    var calButtons = document.getElementById('cal-buttons');
    if (calButtons) calButtons.style.display = '';
  }
})();
</script>

