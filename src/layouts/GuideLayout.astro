/* ── FOCUS + GUARANTEE ── */
.focus-section{padding:96px 0;border-top:1px solid rgba(255,255,255,.05)}
.focus-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.focus-card{
  padding:52px 52px;border-radius:24px;
  border:1px solid rgba(255,255,255,.07);
  background:var(--bg1);
}
.focus-icon{
  width:48px;height:48px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:24px;
}
.focus-icon svg{width:22px;height:22px}
.focus-card.focus-a .focus-icon{background:rgba(149,80,255,.12);border:1px solid rgba(149,80,255,.2)}
.focus-card.focus-a .focus-icon svg{stroke:var(--pu3)}
.focus-card.focus-b .focus-icon{background:rgba(15,242,200,.1);border:1px solid rgba(15,242,200,.18)}
.focus-card.focus-b .focus-icon svg{stroke:var(--teal)}
.focus-h3{font-size:20px;font-weight:700;letter-spacing:-.02em;margin-bottom:14px}
.focus-body{font-size:16px;color:var(--t1);line-height:1.75}
.guarantee-highlight{
  margin-top:20px;padding:16px 20px;border-radius:12px;
  background:rgba(15,242,200,.06);border:1px solid rgba(15,242,200,.15);
  font-size:14px;font-weight:600;color:var(--teal);line-height:1.5;
}

/* ── WHAT WE'LL COVER ── */
.cover-section{padding:96px 0;border-top:1px solid rgba(255,255,255,.05)}
.cover-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.cover-text .lbl{display:block;margin-bottom:16px}
.cover-h2{font-size:clamp(24px,3vw,40px);font-weight:700;letter-spacing:-.03em;line-height:1.06;margin-bottom:16px}
.cover-h2 em{font-size:1.04em}
.cover-sub{font-size:16px;color:var(--t1);line-height:1.75}
.cover-list{display:flex;flex-direction:column;gap:16px}
.cover-item{
  display:flex;align-items:flex-start;gap:16px;
  padding:20px 24px;border-radius:14px;
  background:var(--bg1);border:1px solid rgba(255,255,255,.05);
  transition:border-color .2s;
}
.cover-item:hover{border-color:rgba(149,80,255,.2)}
.cover-check{
  width:24px;height:24px;border-radius:50%;
  background:rgba(149,80,255,.12);border:1px solid rgba(149,80,255,.2);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;margin-top:1px;
}
.cover-check svg{width:11px;height:11px;stroke:var(--pu3);stroke-width:2.5;fill:none}
.cover-item-text{font-size:16px;color:rgba(240,237,231,.75);line-height:1.55}

/* ── PORTFOLIO ── */
.portfolio{padding:96px 0;border-top:1px solid rgba(255,255,255,.05)}
.portfolio-header{text-align:center;margin-bottom:64px}
.portfolio-header .lbl{display:block;margin-bottom:16px}
.port-h2{font-size:clamp(24px,3vw,40px);font-weight:700;letter-spacing:-.03em;line-height:1.06}
.port-h2 em{font-size:1.06em}
.port-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.05);border-radius:20px;overflow:hidden}
.port-item{
  background:var(--bg);padding:36px 36px;
  display:flex;flex-direction:column;gap:12px;
}
.port-item:hover{background:var(--bg1)}
.port-num{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(240,237,231,.2)}
.port-name{font-size:17px;font-weight:700;letter-spacing:-.02em;color:var(--t0)}
.port-domain{font-size:11px;color:var(--pu3);opacity:.7;margin-bottom:4px}
.port-desc{font-size:16px;color:var(--t1);line-height:1.65;flex:1}
.port-link{
  display:inline-flex;align-items:center;gap:6px;
  font-size:11px;font-weight:600;color:rgba(240,237,231,.45);
  margin-top:8px;transition:color .18s;
}
.port-link:hover{color:var(--t0)}
.port-link svg{width:12px;height:12px;stroke:currentColor;stroke-width:2;fill:none;transition:transform .18s}
.port-link:hover svg{transform:translate(2px,-2px)}
.port-item.rev{opacity:1;transform:none;transition:none}
.port-item.rev>*{opacity:0;transform:translateY(14px);transition:opacity .55s var(--ease),transform .55s var(--ease)}
.port-item.rev.in>*{opacity:1;transform:translateY(0)}

/* ── HERO LAYOUT ── */
.vid-confirm{padding-bottom:80px!important}
.confirm-flat{max-width:680px;margin:48px auto 0;padding:0 24px}
@media(max-width:760px){.vid-confirm{padding-bottom:50px!important}}

/* ── FLAT BOOKING CONFIRMATION ── */
.booking-card{
  position:relative;margin:0;width:100%;
  background:none;border:none;border-radius:0;box-shadow:none;
  padding:0;text-align:center;
}

.booking-time-row{
  display:flex;justify-content:center;align-items:stretch;
  padding-bottom:32px;
}
.booking-time-block{
  display:flex;flex-direction:column;gap:8px;align-items:center;text-align:center;
