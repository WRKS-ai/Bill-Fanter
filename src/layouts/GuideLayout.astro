  border-right:1px solid rgba(255,255,255,.08);
}
.booking-time-date{
  font-size:14px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  color:var(--pu3);
}
.booking-time-time{
  font-size:clamp(28px,3.4vw,40px);font-weight:700;letter-spacing:-.03em;line-height:1;
  color:var(--t0);
  white-space:nowrap;
}

.booking-countdown-block{
  display:flex;flex-direction:column;gap:8px;align-items:center;text-align:center;
  padding:0 24px;
}
.booking-countdown-lbl{
  font-size:14px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  color:var(--pu3);
}
.booking-countdown-val{
  font-size:clamp(28px,3.4vw,40px);font-weight:700;letter-spacing:-.03em;line-height:1;
  color:var(--t0);
  font-variant-numeric:tabular-nums;
  white-space:nowrap;
}

.booking-fallback{
  padding-bottom:28px;
  font-size:16px;color:rgba(240,237,231,.6);text-align:center;line-height:1.5;
}

.booking-cal{padding-top:28px}
.booking-cal-lbl{
  display:block;font-size:11px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
  color:rgba(240,237,231,.45);margin-bottom:16px;
}
.booking-cal-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}

.cal-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  padding:12px 22px;border-radius:10px;
  font-size:16px;font-weight:600;text-decoration:none;
  background:transparent;
  border:1px solid rgba(255,255,255,.12);
  color:var(--t0);
  transition:background .15s,border-color .15s;
}
.cal-btn:hover{
  background:rgba(255,255,255,.04);
  border-color:rgba(255,255,255,.25);
}
.cal-btn svg{width:16px;height:16px;flex-shrink:0;opacity:.7}

@media(max-width:760px){
  .confirm-flat{margin-top:32px}
  .booking-time-row{flex-direction:column;gap:24px}
  .booking-time-block{align-items:center;text-align:center;padding:0 0 24px;border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}
  .booking-countdown-block{align-items:center;text-align:center;padding:0}
  .cal-btn{flex:1 1 100%;min-width:0}
}

/* ── FOOTER ── */
@media(max-width:760px){
  .portfolio,.testimonials,.focus-section,.cover-section{padding:50px 0}
  .case-section{padding:50px 0 50px!important}
  .port-grid{grid-template-columns:1fr}
  .case-inner,.testi-grid,.focus-grid,.cover-inner{grid-template-columns:1fr}
  .case-content,.case-stats{padding:32px 24px}
  .case-stats{order:-1;border-bottom:1px solid rgba(255,255,255,.06);gap:18px}
  .case-stat{display:flex;align-items:center;gap:18px}
  .case-stat-num{flex-shrink:0;width:170px;font-size:32px;line-height:1;margin-bottom:0;white-space:nowrap}
  .case-stat-label{font-size:14px;line-height:1.4}
  .case-content{border-right:none}
  .cover-inner{gap:40px}
  .guide-hero-bottom{padding:40px 28px 44px;margin-top:72px}
  .cta-sub{font-size:16px}
  .focus-card{padding:36px 28px}
  .tquote{padding:36px 28px}
  .rev{opacity:1;transform:none;transition:none}
  .port-item.rev>*,.tquote.rev>*{opacity:1;transform:none;transition:none}
}
