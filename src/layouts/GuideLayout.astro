---
/**
 * GuideLayout.astro — single template for every page in /guide/.
 *
 * These are POST-BOOKING confirmation pages, NOT lead-capture pages. The
 * prospect already booked a discovery call upstream (GHL calendar) and lands
 * here with `?name=&start=&end=&loc=&tz=`. The page renders their name + booked
 * time and offers add-to-calendar buttons. No form, no submission to /api/*.
 *
 * Per-vertical data: title/description, the Claxton case-study tile stat,
 * the "what we'll cover" bullets, the BLAS slider H3 copy, the iCal description
 * suffix, and a single boolean for whether to fire the Meta conversion pixel
 * (only `law-firms`, not the entry/unqualified variant).
 *
 * Receives: a `Guide` data entry from src/data/guides.ts.
 */
import DarkVeil from '../components/react/DarkVeil.jsx';
import BaseLayout from './BaseLayout.astro';
import type { Guide } from '../data/guides';

interface Props {
  data: Guide;
}

const { data } = Astro.props;
---

<BaseLayout
  title={data.title}
  description={data.description}
  wfPageId="funnel-guide"
  extraHeadHtml='<meta name="robots" content="noindex, nofollow">'
>

<style is:global>
/* WRKS funnel design tokens (ported from wrksonline.com — reconfigure for Bill). */
:root{
  --bg:#000;--bg1:#111111;--t0:#F0EDE7;--t1:#bdbdbd;--t2:#8a8a8a;
  --pu:#6214d9;--pu3:#9550ff;
  --sans:'DM Sans',system-ui,sans-serif;--ease:cubic-bezier(0.22,1,0.36,1);
}
body{background:var(--bg);color:var(--t0)}
/* Override global vid-disc-label for this funnel */
.vid-disc-label{font-size:22px!important;letter-spacing:.16em!important;margin-bottom:24px!important}
@media(max-width:640px){.vid-disc-label{font-size:14px!important;letter-spacing:.08em!important;margin-bottom:18px!important}}
.vid-confirm-h1{margin:0 auto 20px!important;max-width:760px}
.vid-confirm-sub{margin:0 auto 48px!important;max-width:540px}

/* ── HERO ── */
.guide-hero{
  padding-top:64px;
  display:flex;align-items:center;justify-content:center;min-height:auto;
}
.guide-hero-inner{
  max-width:1200px;margin:0 auto;
  padding:100px 56px 120px;
  position:relative;z-index:1;
}
@media(max-width:1024px){.guide-hero-inner{padding:48px 32px 40px}}
@media(max-width:760px){.guide-hero{padding-top:36px}.guide-hero-inner{padding:0 24px 20px}}
.guide-hero-bottom{
  max-width:720px;margin:0 auto;
  text-align:center;
}

/* ── BLAS V3 SLIDER ── */
.blas3-section{padding:100px 0 80px;position:relative;border-top:1px solid rgba(255,255,255,.05)}
.blas3-header{max-width:1200px;margin:0 auto;padding:0 56px;display:grid;grid-template-columns:1fr 0.65fr;gap:48px;align-items:start;margin-bottom:52px}
.blas3-hl .lbl{display:block;margin-bottom:20px}
.blas3-h2{font-size:clamp(32px,4vw,56px);font-weight:800;letter-spacing:-.04em;line-height:1.06;margin:0}
.blas3-h2 em{font-size:1.03em}
.blas3-right{display:flex;flex-direction:column;justify-content:flex-start;gap:24px}
.blas3-sub{font-size:18px;color:var(--t1);line-height:1.75}
.blas3-cta{display:inline-flex;align-items:center;gap:8px;font-size:16px;font-weight:600;color:var(--t0);text-decoration:none;width:fit-content}
.blas3-cta svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.blas3-cta:hover{color:var(--pu3)}
.blas3-showcase-wrap{max-width:1200px;margin:0 auto;padding:0 56px;margin-bottom:20px}
.blas3-showcase{border-radius:20px;overflow:hidden;position:relative;height:480px;isolation:isolate;background:#000}
/* DarkVeil sits inside the showcase as the base background. */
.blas3-veil{position:absolute;inset:0;z-index:0;pointer-events:none;opacity:1}
.blas3-veil canvas{display:block;width:100%;height:100%}
/* Per-step gradients become HUE OVERLAYS over the DarkVeil. Each
   step tints the same flowing motion a different color via
   mix-blend-mode:hue. */
.blas3-sc-bg{position:absolute;inset:0;z-index:1;opacity:0;transition:opacity .9s ease;mix-blend-mode:hue;pointer-events:none}
.blas3-sc-bg.active{opacity:1}
.blas3-sc-bg[data-scbg="build"] {background:linear-gradient(135deg,#1a3eff 0%,#3a5fcf 50%,#7c44e8 100%)}
.blas3-sc-bg[data-scbg="launch"]{background:linear-gradient(135deg,#ff6b7c 0%,#ff9aa6 50%,#ffd6dc 100%)}
.blas3-sc-bg[data-scbg="adapt"] {background:linear-gradient(135deg,#ff2d8a 0%,#c020cc 50%,#6b0ea0 100%)}
.blas3-sc-bg[data-scbg="scale"] {background:linear-gradient(135deg,#5810c8 0%,#7c44e8 50%,#9240ff 100%)}
.blas3-sc-grain{position:absolute;inset:0;z-index:1;pointer-events:none;opacity:.055;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:180px}
.blas3-sc-vig{position:absolute;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse at 60% 50%,transparent 30%,rgba(0,0,0,.45) 100%)}
.blas3-sc-panel{position:absolute;inset:0;z-index:2;display:flex;flex-direction:row;align-items:center;padding:40px 56px;gap:48px;opacity:0;transition:opacity .7s ease;pointer-events:none}
.blas3-sc-panel.active{opacity:1;pointer-events:auto}
.blas3-sc-left{flex:0 0 40%;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:1}
.blas3-sc-right{flex:1;display:flex;align-items:center;justify-content:flex-end;position:relative;z-index:1}
.blas3-sc-num{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.75);margin-bottom:14px}
.blas3-sc-num .sc-n{color:rgba(255,255,255,.35);letter-spacing:.15em}
.blas3-sc-name{font-size:clamp(20px,2.4vw,32px);font-weight:800;letter-spacing:-.04em;line-height:1.08;color:#fff;margin:0 0 14px}
.blas3-sc-name em{font-size:1.04em}
.blas3-sc-dots{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:0;z-index:5}
.blas3-sc-dot{width:44px;height:44px;padding:0;border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative}
.blas3-sc-dot::before{content:"";display:block;width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.32);transition:all .4s ease}
.blas3-sc-dot.active::before{width:28px;border-radius:4px;background:rgba(255,255,255,.9)}
.blas3-sc-dot:focus-visible{outline:none}
.blas3-sc-dot:focus-visible::before{box-shadow:0 0 0 2px rgba(149,80,255,.7)}
.blas3-sc-pbar{display:none}
.bm-card{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.16);border-radius:16px;backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);padding:22px 26px;width:100%;max-width:340px;box-shadow:0 4px 32px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.12)}
.bm-svc-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px 12px}
.bm-svc{display:flex;align-items:center;gap:9px;opacity:0;transform:translateY(8px);transition:opacity .35s ease,transform .35s ease}
.bm-svc.in{opacity:1;transform:translateY(0)}
.bm-svc span{font-size:11.5px;color:rgba(255,255,255,.82);font-weight:500;letter-spacing:-.01em}
.bm-svc-icon{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bm-svc-icon svg{width:12px;height:12px}
.bm-deploy-wrap{width:100%;max-width:340px}
.bm-deploy-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.bm-deploy-title{font-size:9.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.42)}
.bm-deploy-count{font-size:11px;font-weight:800;color:rgba(255,255,255,.7);font-variant-numeric:tabular-nums}
.bm-deploy-pbar{height:3px;background:rgba(255,255,255,.12);border-radius:2px;margin-bottom:16px;overflow:hidden}
.bm-deploy-pfill{height:100%;width:0%;background:rgba(255,255,255,.72);border-radius:2px;transition:width .35s ease}
.bm-deploy-list{display:flex;flex-direction:column;gap:8px}
.bm-deploy-row{display:flex;align-items:center;gap:9px;opacity:0;transform:translateX(-8px);transition:opacity .3s ease,transform .3s ease}
.bm-deploy-row.in{opacity:1;transform:translateX(0)}
.bm-deploy-dot{width:15px;height:15px;border-radius:50%;border:1.5px solid rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(255,255,255,.04);transition:background .3s ease,border-color .3s ease}
.bm-deploy-row.in .bm-deploy-dot{background:rgba(255,255,255,.88);border-color:rgba(255,255,255,.88)}
.bm-deploy-dot svg{width:7px;height:7px;stroke:#c2410c;stroke-width:2.5;fill:none;opacity:0;transition:opacity .2s .15s ease}
.bm-deploy-row.in .bm-deploy-dot svg{opacity:1}
.bm-deploy-name{flex:1;font-size:12px;font-weight:600;color:rgba(255,255,255,.32);transition:color .3s ease}
.bm-deploy-row.in .bm-deploy-name{color:rgba(255,255,255,.88)}
.bm-deploy-tag{font-size:8px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;padding:2px 7px;border-radius:10px;border:1px solid rgba(255,255,255,.22);color:rgba(255,255,255,.75);opacity:0;transition:opacity .3s .2s ease;white-space:nowrap}
.bm-deploy-row.in .bm-deploy-tag{opacity:1}
.bm-metrics{width:100%;max-width:340px;display:flex;flex-direction:column;gap:8px}
.bm-metric-card{background:rgba(255,255,255,.08);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.13);border-radius:10px;padding:11px 14px;display:flex;align-items:center;gap:10px;opacity:0;transform:translateX(12px);transition:opacity .4s ease,transform .4s ease;box-shadow:0 2px 16px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.1)}
.bm-metric-card.in{opacity:1;transform:translateX(0)}
.bm-metric-info{display:flex;flex-direction:column;gap:2px;flex:1}
.bm-metric-name{font-size:12px;font-weight:600;color:rgba(255,255,255,.78)}
.bm-metric-tgt{font-size:10px;color:rgba(255,255,255,.35);font-weight:500}
.bm-metric-bar{height:3px;background:rgba(255,255,255,.1);border-radius:2px;width:80px;margin-top:5px;overflow:hidden}
.bm-metric-bar-fill{height:100%;border-radius:2px;width:0%;transition:width 1.2s cubic-bezier(.16,1,.3,1);background:linear-gradient(90deg,#e040fb,#f472b6)}
.bm-metric-val{font-size:20px;font-weight:800;letter-spacing:-.03em;color:#f0abfc;font-variant-numeric:tabular-nums;width:68px;text-align:right;flex-shrink:0;margin-right:10px}
.bm-status-pill{display:inline-flex;align-items:center;gap:4px;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:2px 7px 2px 5px;border-radius:20px;background:rgba(224,64,251,.12);color:#f0abfc;border:1px solid rgba(224,64,251,.25);opacity:0;transform:translateY(4px);transition:opacity .3s ease,transform .3s ease;margin-top:6px;white-space:nowrap}
.bm-status-pill::before{content:'';width:5px;height:5px;border-radius:50%;background:#e040fb;flex-shrink:0}
.bm-status-pill.in{opacity:1;transform:translateY(0)}
.bm-scale-v3{width:100%;max-width:340px}
.bm-sv3-kpi{display:flex;align-items:baseline;gap:10px;margin-bottom:4px}
.bm-sv3-val{font-size:34px;font-weight:800;letter-spacing:-.04em;color:#fff;font-variant-numeric:tabular-nums;line-height:1}
.bm-sv3-delta{font-size:13px;font-weight:700;color:#c084fc}
.bm-sv3-lbl{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.24);margin-bottom:8px}
.bm-sv3-svg{width:100%;height:52px;overflow:visible;display:block;margin-bottom:14px}
.bm-sv3-path{fill:none;stroke:url(#scaleGrad);stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.bm-sv3-area{fill:url(#scaleAreaGrad);opacity:.18}
.bm-sv3-dot{fill:#9550ff;filter:drop-shadow(0 0 6px rgba(149,80,255,.9))}
.bm-sv3-bars{display:flex;flex-direction:column;gap:10px}
.bm-sv3-row{display:flex;align-items:center;gap:10px;opacity:0;transform:translateX(8px);transition:opacity .4s ease,transform .4s ease}
.bm-sv3-row.in{opacity:1;transform:translateX(0)}
.bm-sv3-name{font-size:11px;font-weight:600;color:rgba(255,255,255,.42);width:44px;flex-shrink:0}
.bm-sv3-track{flex:1;height:5px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden}
.bm-sv3-fill{height:100%;width:0%;border-radius:3px;background:linear-gradient(90deg,#9550ff,#c084fc);transition:width 1.2s cubic-bezier(.16,1,.3,1)}
.bm-sv3-roas{font-size:12px;font-weight:800;color:#c084fc;font-variant-numeric:tabular-nums;width:32px;text-align:right;flex-shrink:0}
.blas3-cols-wrap{max-width:1200px;margin:0 auto;padding:0 56px}
.blas3-grid{display:grid;grid-template-columns:repeat(4,1fr);padding-top:48px;gap:0}
.blas3-col{padding:24px clamp(20px,2.5vw,40px) 40px;display:flex;flex-direction:column;cursor:pointer;position:relative;border-top:1px solid rgba(255,255,255,.08);transition:background .25s ease}
.blas3-col::before{content:'';position:absolute;top:-1px;left:0;width:0;height:2px;background:var(--cc);transition:width .5s cubic-bezier(.16,1,.3,1)}
.blas3-col.active::before{width:100%}
.blas3-col:hover{background:rgba(255,255,255,.025)}
.blas3-col-num{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-bottom:14px;transition:color .25s ease}
.blas3-col.active .blas3-col-num{color:var(--cc)}
.blas3-col-word{font-family:var(--serif);font-style:italic;font-size:clamp(26px,3vw,42px);font-weight:400;letter-spacing:-.02em;line-height:1;color:var(--t0);margin-bottom:16px}
.blas3-col[data-col="build"]{--cc:#4776e6;--cg:linear-gradient(135deg,#4776e6,#8e54e9)}
.blas3-col[data-col="launch"]{--cc:#ff3a4a;--cg:linear-gradient(135deg,#ff2032,#ff3a4a)}
.blas3-col[data-col="adapt"]{--cc:#e040fb;--cg:linear-gradient(135deg,#ff6b35,#e040fb)}
.blas3-col[data-col="scale"]{--cc:#9550ff;--cg:linear-gradient(135deg,#9550ff,#6214d9)}
.blas3-mobile-tabs{display:none;gap:6px;padding:12px 0 0;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.blas3-mobile-tabs::-webkit-scrollbar{display:none}
.bmt{flex:1;min-width:0;font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:8px 6px;border-radius:8px;border:1px solid rgba(255,255,255,.18);background:rgba(10,10,10,.55);color:rgba(255,255,255,.78);cursor:pointer;transition:background .22s ease,border-color .22s ease,color .22s ease;white-space:nowrap;text-align:center}
.bmt.active{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.32);color:#fff}
.bm-live-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.9);flex-shrink:0;animation:bmLivePulse 1.4s ease-in-out infinite}
@keyframes bmLivePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.78)}}
@media(max-width:1024px){
  .blas3-section{padding:50px 0 50px}
  .blas3-header{grid-template-columns:1fr;gap:20px;padding:0 32px;margin-bottom:32px}
  .blas3-showcase-wrap{padding:0 20px}
  .blas3-showcase{height:390px}
  .blas3-sc-panel{flex-direction:column;padding:40px 20px 22px;gap:8px;justify-content:flex-start;align-items:flex-start}
  .blas3-sc-left{flex:none;width:100%}
  .blas3-sc-name{font-size:20px;line-height:1.15;margin-bottom:8px}
  .blas3-sc-desc{font-size:14.5px;line-height:1.55;color:rgba(255,255,255,.78)}
  .blas3-sc-num{margin-bottom:4px}
  .blas3-sc-right{display:flex;width:100%;justify-content:flex-start}
  .blas3-sc-dots{display:none}
  .blas3-mobile-tabs{display:flex}
  .bm-card,.bm-deploy-wrap,.bm-metrics,.bm-scale-v3{max-width:100%;width:100%}
  .bm-metrics{display:grid;grid-template-columns:1fr 1fr;gap:7px}
  .bm-metric-card{flex-direction:column;align-items:flex-start;gap:3px;padding:10px 11px}
  .bm-metric-val{font-size:18px}
  .bm-metric-bar{width:100%;margin-top:4px}
  .bm-status-pill{display:none}
  .bm-svc-grid{gap:7px 10px}
  .bm-svc span{font-size:11px}
  .bm-sv3-svg{height:44px}
  .blas3-cols-wrap{display:none}
  .blas3-header{padding:0 20px}
}

/* ── CASE STUDY (cs-card template ported from case-studies index) ── */
.case-section{padding:80px 0 96px;border-top:1px solid rgba(255,255,255,.05)}
.cs-card{
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.cs-card-top{display:block;margin-bottom:24px}
.cs-client{
  font-size:clamp(34px,4vw,52px);font-weight:700;
  letter-spacing:-.03em;line-height:1.05;margin-bottom:16px;
}
.cs-tagline{font-size:16px;color:var(--t1);line-height:1.75;margin-bottom:32px;max-width:440px}
.cs-link{
  display:inline-flex;align-items:center;gap:8px;
  font-size:14px;font-weight:600;color:var(--t1);
  padding:11px 22px;border-radius:100px;
  border:1px solid rgba(255,255,255,.12);
  text-decoration:none;
  transition:all .2s;white-space:nowrap;
  margin-top:8px;width:fit-content;
}
.cs-link:hover{border-color:rgba(255,255,255,.28);color:var(--t0);transform:translateY(-2px);gap:12px}
.cs-link svg{width:15px;height:15px;flex-shrink:0}
.cs-tile-card{display:flex;flex-direction:column;background:var(--bg1);border:1px solid rgba(255,255,255,.07);border-radius:24px;overflow:hidden;text-decoration:none;transition:transform .35s ease,box-shadow .35s ease,border-color .35s ease;box-shadow:0 16px 40px rgba(0,0,0,.2),0 4px 10px rgba(0,0,0,.14)}
.cs-tile-card:hover{transform:translateY(-4px);border-color:rgba(149,80,255,.32);box-shadow:0 20px 50px rgba(149,80,255,.16),0 6px 14px rgba(0,0,0,.18)}
.cs-tile-canvas{position:relative;aspect-ratio:5/3;background:#000;overflow:hidden}
.cs-tile-bg{display:block;width:100%;height:100%;object-fit:cover;object-position:top center}
.cs-tile-stats{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid rgba(255,255,255,.07)}
.cs-tile-stat{padding:32px 28px;display:flex;flex-direction:column;gap:10px}
.cs-tile-stat:first-child{border-right:1px solid rgba(255,255,255,.07)}
.cs-tile-stat-fig{font-size:clamp(20px,2.2vw,28px);font-weight:700;letter-spacing:-.03em;line-height:1.1;white-space:nowrap;background:linear-gradient(135deg,#fff 0%,rgba(149,80,255,.9) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.cs-tile-stat-desc{font-size:14px;color:var(--t1);line-height:1.5}
@media(max-width:900px){
  .cs-card{grid-template-columns:1fr;gap:24px}
  .cs-card-left,.cs-card-right{display:contents}
  .cs-card-top{order:1;margin-bottom:0}
  .cs-client{order:1;margin-bottom:0}
  .cs-card-left blockquote{order:2;margin:0!important}
  .cs-tile-card{order:3}
  .cs-tagline{order:4;margin-bottom:0;max-width:none}
  .cs-link{order:5;margin-top:0;align-self:flex-start}
  .cs-tile-stats{grid-template-columns:1fr}
  .cs-tile-stat{padding:24px 22px}
  .cs-tile-stat:first-child{border-right:none;border-bottom:1px solid rgba(255,255,255,.07)}
  .cs-tile-stat-fig{font-size:24px}
}

/* ── TESTIMONIALS ── */
.testimonials{padding:96px 0;border-top:1px solid rgba(255,255,255,.05)}
.testi-header{text-align:center;margin-bottom:56px}
.testi-header .lbl{display:block;margin-bottom:16px}
.testi-h2{font-size:clamp(32px,4vw,52px);font-weight:700;letter-spacing:-.03em;line-height:1.06}
.testi-h2 em{font-size:1.06em}
.testi-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:rgba(255,255,255,.05);
  border-radius:20px;overflow:hidden;
}
.tquote{
  padding:56px 52px;background:var(--bg);
  position:relative;display:flex;flex-direction:column;justify-content:space-between;
}
.tquote-stars{display:flex;gap:3px;margin-bottom:24px}
.tquote-stars svg{width:13px;height:13px;fill:#f5c518;stroke:none}
.tquote-text{
  font-family:var(--serif);font-style:italic;
  font-size:clamp(22px,2.4vw,32px);font-weight:400;
  line-height:1.3;color:var(--t0);letter-spacing:-.02em;
