---
// Componentized homepage — work in progress. Assembled entirely from clean
// Astro section components (no Webflow markup / no _body.html blob). Built on
// /v2 so /sandbox stays as the reference to diff against; swapped to / when
// it's complete and QA'd. noindex until then.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Footer from '../../components/Footer.astro';
import HelpGrid from '../../components/sections/HelpGrid.astro';
import YoutubeCta from '../../components/sections/YoutubeCta.astro';
import AboutBill from '../../components/sections/AboutBill.astro';
import Closing from '../../components/sections/Closing.astro';

const noindexTag = '<meta name="robots" content="noindex, nofollow" />';
---
<BaseLayout
  title="Home (v2) | Bill Fanter"
  description="Componentized homepage — work in progress."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="664a5b263659c7265be280e3"
  extraHeadHtml={noindexTag}
>
  <ReactReady client:only="react" />
  <main class="bf-page">
    <HelpGrid />
    <YoutubeCta />
    <AboutBill />
    <Closing />
  </main>
  <Footer />
</BaseLayout>
