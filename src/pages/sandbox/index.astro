---
// Sandbox — a fresh clone of the production homepage you can iterate on
// without touching `/`. Sister to `/2026` (which holds the bf-* design
// preview) and `/classic` (the frozen Webflow rollback).
//
// Excluded from the sitemap + marked noindex so crawlers ignore it.
import BaseLayout from '../../layouts/BaseLayout.astro';
import bodyHtml from './_body.html?raw';
import extraHeadHtml from './_head.html?raw';
import ReactReady from '../../components/ReactReady.jsx';
import Footer from '../../components/Footer.astro';

const noindexTag = '<meta name="robots" content="noindex, nofollow" />';
---
<BaseLayout
  title={`Sandbox | Bill Fanter`}
  description={`Sandbox preview — internal use.`}
  ogImage={`/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp`}
  wfPageId={`664a5b263659c7265be280e3`}
  extraHeadHtml={noindexTag + extraHeadHtml}
>
  {/* ------------------------------------------------------------------
      SANDBOX-ONLY iteration overrides. This file only loads on /sandbox,
      so is:global here can't leak into production. modernization.css is no
      longer loaded here — the sandbox is being rebuilt on bf-design-system.css
      + these overrides as a clean slate. */}
  <style is:global>
    /* Legacy hero headline — larger + heavier */
    .section_home-hero .heading-style-h1 {
      font-size: 5.5rem !important;
      font-weight: 600 !important;
      letter-spacing: -0.03em !important;
      line-height: 1.04 !important;
    }

    /* Align every 2026 bf-* section to the same left rail as the hero.
       They sit inside padding-global > container-large already; their own
       inner max-width + 24px side padding was pushing them in. Drop it. */
    .bf-page .bf-hero-split__grid,
    .bf-page .bf-watchlist-v2,
    .bf-page .bf-container {
      max-width: none !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    /* bf-hero-split: images LEFT, text RIGHT (swap column order) */
    .bf-hero-split__bento { order: 1 !important; }
    .bf-hero-split__copy { order: 2 !important; }
    /* After the swap the copy sits in the RIGHT column with the media on its
       left; the design's separation was built for copy-on-left, so the text
       ended up hugging the bento. Add left padding so the two-column gap reads
       evenly (its slack was landing on the outer/right side instead). */
    .bf-hero-split__copy { padding-left: 48px !important; }

    /* bf-hero-split headline — match "Get your free weekly trading
       advantage" size */
    .bf-hero-split__copy .bf-h1 {
      font-size: clamp(24px, 2.6vw, 36px) !important;
    }

    /* (bf-hero-split keeps its design-system symmetric padding:
       `var(--bf-section-pad) 0` — equal top/bottom like the rest of the site.
       The earlier 112px top override made it lopsided, so it's removed.) */

    /* Bulletproof the hero CTAs into pills — high specificity so no
       legacy Webflow / modernization cascade can square them off. */
    .section_home-hero .bf-btn {
      display: inline-flex !important;
      width: auto !important;
      border-radius: 999px !important;
      padding: 14px 26px !important;
      white-space: nowrap !important;
    }
    /* The button wrapper carries class="bf-page" (so .bf-page .bf-btn
       styles apply) but .bf-page also paints a near-white background —
       that was the "white box" behind the buttons. Kill it. */
    .section_home-hero .bf-page {
      background: transparent !important;
    }

    /* Trusted ★★★★★ 500+ Students row, sitting below the hero CTAs. */
    .section_home-hero .bf-hero-trust {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 28px;
      /* Nudge ever so slightly right to correct an optical-alignment illusion
         against the pill CTAs above (their text sits inset from the pill edge). */
      margin-left: 6px;
      color: #fff;
      font-size: 14px;
      font-weight: 500;
    }
    .section_home-hero .bf-hero-trust .bf-closing__rating-stars {
      display: inline-flex;
      gap: 2px;
    }
    .section_home-hero .bf-hero-trust__count {
      color: rgba(255, 255, 255, 0.72);
      font-weight: 400;
    }

    /* Widen the hero headline — its .max-width-medium wrapper caps it at
       ~518px, forcing a cramped 6-line wrap. Give it more room. */
    .section_home-hero .max-width-medium {
      max-width: 820px !important;
    }

    /* Double the top padding on the watchlist section so it sits
       equidistant between the hero (above) and the community (below). */
    .bf-page #watchlist.bf-section,
    #watchlist.bf-section {
      padding-top: calc(var(--bf-section-pad) * 2) !important;
    }

    /* Nav Login button — make it minimal / SaaS-like instead of a solid
       blue gradient CTA. Quiet text link with a subtle outline. */
    .button-4,
    .button-4.hide-mobile-portrait.dektop-login-btn {
      background-image: none !important;
      background-color: transparent !important;
      color: #0a0a0a !important;
      border: 1px solid rgba(10, 10, 10, 0.16) !important;
      font-weight: 600 !important;
    }
    .button-4:hover {
      background-color: rgba(10, 10, 10, 0.05) !important;
      color: #0a0a0a !important;
      border-color: rgba(10, 10, 10, 0.32) !important;
    }

    /* Grow the hero image leftward so its left edge lines up with the
       bento split below (the dark "Receive a curated list" card). The
       image is absolute, right-anchored; setting left as a viewport %
       keeps the alignment stable across widths. */
    .section_home-hero .hero_image-wrapper {
      left: 57% !important;
      right: 0 !important;
      /* Webflow sets an explicit width on the wrapper; with left+right+width
         all specified the box is over-constrained and `right: 0` is ignored,
         leaving a black strip at the page's right edge. Drop the fixed width
         so left+right define it and the image reaches the true right edge. */
      width: auto !important;
    }
    /* Image fills its wrapper edge-to-edge (no gap on the right). Anchor the
       crop to the TOP so the subject's head stays in frame and any overflow
       is trimmed from the bottom instead. */
    .section_home-hero .hero_image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center top !important;
    }

    /* Hero sizing: let the section hug its content instead of forcing
       88vh — that min-height was taller than .hero_component (which the
       image wrapper is anchored to), leaving a dead black band below the
       image. With min-height gone, section height == content height, so
       the image fills the hero edge-to-edge. Then trim the oversized
       140px section padding so the hero isn't so tall overall. */
    .section_home-hero {
      min-height: 0 !important;
    }
    /* Hero height is driven by this section padding (NOT min-height) — the
       image wrapper is anchored to .hero_component, so growing the content
       box grows the image with it and it keeps filling edge-to-edge. Extra
       class (.container-large) outranks modernization.css's 140px rule
       without editing that shared file. Scaled down at smaller breakpoints
       so the hero stays proportionate on tablet/mobile. */
    .section_home-hero .container-large .padding-section-large {
      padding-top: 184px !important;
      padding-bottom: 184px !important;
    }
    @media (max-width: 991px) {
      .section_home-hero .container-large .padding-section-large {
        padding-top: 136px !important;
        padding-bottom: 136px !important;
      }
    }
    @media (max-width: 767px) {
      .section_home-hero .container-large .padding-section-large {
        padding-top: 88px !important;
        padding-bottom: 88px !important;
      }
    }

    /* --- Login button: minimal/SaaS treatment on BOTH the desktop nav
       (.button-4) and the mobile-menu login (.humburger-login). --- */
    .button-4,
    .button-4.hide-mobile-portrait.dektop-login-btn,
    .button.humburger-login,
    .humburger-login {
      background-image: none !important;
      background-color: transparent !important;
      color: #0a0a0a !important;
      border: 1px solid rgba(10, 10, 10, 0.16) !important;
      font-weight: 600 !important;
    }
    .button-4:hover,
    .button.humburger-login:hover,
    .humburger-login:hover {
      background-color: rgba(10, 10, 10, 0.05) !important;
      color: #0a0a0a !important;
      border-color: rgba(10, 10, 10, 0.32) !important;
    }

    /* --- Logo: keep it inside the content rail (not flush to the page
       edge) by aligning the nav to the same container as the body. --- */
    .navbar .padding-global.nav {
      padding-left: 5% !important;
      padding-right: 5% !important;
    }

    /* The legacy Webflow navbar is replaced by the React Bits CardNav island
       on /sandbox — hide it so only CardNav shows. */
    .navbar { display: none !important; }

    /* The webinar slot is now the GridDistortion spotlight above; hide the
       original iPad .section_webinar (kept in markup for easy rollback). */
    .section_webinar { display: none !important; }

    /* The YouTube CTA is now the /2026 bf-darkcta (ported above the footer);
       hide the broken Webflow section_youtube (dark band + blue bg bleed). */
    .section_youtube { display: none !important; }

    /* The GridDistortion canvas reacts to mousemove, but it sits BEHIND the
       overlay + content — let pointer events fall through those layers to the
       canvas so the hover distortion works. Keep the CTA itself clickable. */
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__overlay,
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__content {
      pointer-events: none;
    }
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__primary-btn {
      pointer-events: auto;
    }

    /* Remove the left→right dark gradient overlay — the abstract image's left
       side is already dark behind the copy. */
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__overlay {
      background: none !important;
    }
    /* Left-align the copy to the SAME rail the other sections use. Those sit in
       container-large (max-width 1224px) → their content starts ~101px from the
       edge. Match that here (1224px centered, no extra padding) so the webinar
       heading lines up vertically with How-Can-We-Help / hero-split instead of
       hanging ~53px further left. */
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__content--simple {
      max-width: 1224px !important;
      margin: 0 auto !important;
      width: 100% !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      align-items: flex-start !important;
    }
    .bf-spotlight:has([data-griddistortion]) .bf-spotlight__h2 {
      max-width: 560px !important;
    }

    /* --- Blue grainient behind the watchlist "Receive a curated list"
       tile (replaces the flat black). Children float above it. --- */
    .bf-page .bf-watchlist-v2__bento-tile--brand {
      background: #0b1f5c !important;
    }
    .bf-watchlist-v2__bento-tile--brand > *:not([data-grainient]) {
      position: relative;
      z-index: 1;
    }

    /* Brand "past picks" screenshot inside the grainient tile: nudge up ~20px
       and scale 10% larger. Keeps translateX(-50%) for horizontal centering. */
    .bf-page .bf-watchlist-v2__bento-tile--brand .bf-watchlist-v2__brand-picks {
      transform: translateX(-50%) translateY(-40px) scale(1.1) !important;
    }

    /* ---- Watchlist STACKED layout ----------------------------------------
       Copy (heading + body) on top, photo + blue grainient tile bento in the
       middle, full-width Subscribe bar at the bottom. Replaces the too-tall
       split-form layout and reconnects the body copy with the heading. */
    .bf-watchlist-v2.is-stacked {
      display: flex !important;
      flex-direction: column;
      gap: 36px;
      align-items: stretch !important;
    }
    /* Copy header: heading (left column) + body (right column). */
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__copy {
      max-width: none !important;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: end;
    }
    @media (max-width: 800px) {
      .bf-watchlist-v2.is-stacked .bf-watchlist-v2__copy { grid-template-columns: 1fr; gap: 16px; }
    }
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__lead {
      margin-top: 0;
      font-size: clamp(16px, 1.3vw, 18px);
      line-height: 1.55;
      color: #565656;
    }
    /* Bento: 2/3 photo (left) + 1/3 blue watchlist tile (right), equal height. */
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__bento {
      grid-template-columns: 2fr 1fr !important;
      gap: 16px !important;
      align-items: stretch;
    }
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__bento-photo,
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__bento-tile {
      aspect-ratio: auto !important;
      height: 440px;
    }
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__bento-photo {
      border-radius: 12px;
      overflow: hidden;
    }
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__bento-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    /* Form on an all-black, thin, wide bento box to draw attention. */
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__form {
      margin-top: 0 !important;
      width: 100%;
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      align-items: center;
      gap: 12px;
      background: #0a0a0a;
      padding: 14px;
      border-radius: 14px;
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
    }
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__input {
      flex: 1 1 0 !important;
      width: auto !important;
      min-width: 0 !important;
    }
    /* Invert the Subscribe button so it stands out on the black bento. */
    .bf-watchlist-v2.is-stacked .bf-watchlist-v2__submit {
      flex: 0 0 auto !important;
      background: #ffffff !important;
      color: #0a0a0a !important;
    }

    /* Brand-tile statement ("Receive a curated list…") as body copy instead of
       the heading-weight 600 / 26px display treatment. */
    .bf-watchlist-v2__bento-tile--brand .bf-stat {
      font-size: 16px !important;
      font-weight: 400 !important;
      line-height: 1.55 !important;
    }

    /* --- White → off-white fade behind the watchlist + community
       sections, echoing the 2026 bf-stage backdrop. Applied to the
       full-width padding-global wrappers so the fade spans edge-to-edge. */
    /* Paint the fade on each section's FULL-WIDTH .padding-global wrapper
       (x=0, edge-to-edge) rather than the section itself — the section is
       capped to container-large's 1224px, so a gradient on it left bare
       margins. :has() picks out only these two wrappers. The inner
       container-large / bf-page paint flat white over the center, so make
       them transparent and let the full-width gradient show through. */
    .padding-global:has(> .container-large #watchlist) {
      background: linear-gradient(180deg, #ffffff 0%, #fefefe 100%) !important;
    }
    .padding-global:has(> .container-large #community-2026) {
      background: linear-gradient(180deg, #fefefe 0%, #fbfbfb 100%) !important;
    }

    /* Reviews — first pass toward the 2026 vision: swap the dated Webflow beige
       for the soft brand-blue backdrop used across the 2026 sections (the
       LinkedIn testimonial screenshots stay). Also tidy the heading to bf type. */
    .section_reviews {
      background: linear-gradient(180deg, #eef4fc 0%, #f4f8fd 55%, #ffffff 100%) !important;
    }

    /* bf-closing is designed full-bleed (dark bg edge-to-edge; cards centered on
       the --bf-container 1440 rail). The sandbox wraps it in container-large
       (1224), which capped the dark bg — leaving white sides (the "T") — and
       squeezed the cards narrower than /2026. Drop the cap + side padding so it
       spans full width like /2026. */
    .padding-global:has(.bf-closing) {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
    .padding-global:has(.bf-closing) .container-large {
      max-width: none !important;
    }

    /* The ported YouTube CTA + About-Bill sections went full-bleed because the
       sandbox forces .bf-page .bf-container to full width. Re-constrain just
       these two to the content rail (1224, centered) like every other section. */
    .bf-container:has(> .bf-darkcta),
    .bf-container:has(> .bf-about-grid) {
      max-width: 1224px !important;
      margin-left: auto !important;
      margin-right: auto !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
    .section_reviews .home-review-heading {
      font-family: 'Geist', sans-serif !important;
      letter-spacing: -0.02em !important;
    }
    /* Map the React Bits AnimatedList fade (driven via the --bf-reveal CSS
       variable so it dodges modernization.css's global opacity-reset rule)
       onto opacity for the community benefit rows. Higher specificity than
       that [style*="opacity"] rule, so this wins. Defaults to 1 (fully
       visible) when the island hasn't set the variable. */
    .bf-community__benefits .bf-benefit {
      opacity: var(--bf-reveal, 1) !important;
    }

    /* Community phone mockup: slightly smaller + raised. The grid is
       align-items:center, which floated the phones low in the tall row;
       align-self:start lifts them toward the top, and 88% width shrinks
       them a touch (margin-inline:auto keeps them centered horizontally). */
    #community-2026 .bf-community__media {
      align-self: start !important;
    }
    #community-2026 .bf-community__media img {
      width: 88% !important;
      margin-inline: auto !important;
    }

    .padding-global:has(#watchlist) .container-large,
    .padding-global:has(#watchlist) .bf-page,
    .padding-global:has(#community-2026) .container-large,
    .padding-global:has(#community-2026) .bf-page,
    #watchlist.bf-section,
    #community-2026.bf-section {
      background: transparent !important;
    }
  </style>

  {/* Forces the React Fast-Refresh preamble so the manual DotGrid /
      Grainient mounts work in dev (see ReactReady.jsx). */}
  <ReactReady client:only="react" />
  <Fragment set:html={bodyHtml} />

  {/* Global site footer (reusable Astro component, exact /2026 markup). The
      inline footer + youtube CTA were removed from _body.html. */}
  <Footer />

  <script>
    /* Sandbox-tuned Grainient props — softer warp + lower speed than the
       default that BaseLayout's mount uses. Imports are STATIC so Vite's
       React plugin can inject the Fast-Refresh preamble; dynamic
       import('…jsx') throws "@vitejs/plugin-react can't detect preamble".
       Runs alongside BaseLayout's mount but the dataset.gMounted guard
       in BaseLayout prevents double-renders. */
    import * as React from 'react';
    import { createRoot } from 'react-dom/client';
    import Grainient from '../../components/Grainient/Grainient.jsx';
    import AnimatedList from '../../components/AnimatedList/AnimatedList.jsx';
    import CardNav from '../../components/CardNav/CardNav.jsx';
    import GridDistortion from '../../components/GridDistortion/GridDistortion.jsx';

    /* React Bits GridDistortion — WebGL distorted abstract image behind the
       webinar spotlight. Mounts on [data-griddistortion]; image from data-image. */
    const mountGridDistortion = () => {
      const targets = document.querySelectorAll('[data-griddistortion]');
      for (const el of targets) {
        if (el.dataset.gdMounted === '1') continue;
        el.dataset.gdMounted = '1';
        try {
          createRoot(el).render(React.createElement(GridDistortion, {
            imageSrc: el.dataset.image,
            grid: 15,
            mouse: 0.12,
            strength: 0.15,
            relaxation: 0.9,
          }));
        } catch (e) {
          console.error('[bf-griddistortion] render error', e);
        }
      }
    };

    /* React Bits CardNav — replaces the legacy Webflow navbar on /sandbox (the
       old .navbar is hidden via CSS below). Content maps the real site nav into
       three expandable cards; colors/labels are easy to tune. Mounted by
       prepending a host into .page-wrapper (which is position:relative, so
       CardNav's absolute container anchors to the page top). */
    const NAV_ITEMS = [
      { label: 'Learn', bgColor: '#0f1115', textColor: '#ffffff', links: [
        { label: 'Masterclass', href: '/masterclass', ariaLabel: 'Join the Masterclass' },
        { label: 'Free Webinar', href: '/webinar', ariaLabel: 'Watch the free webinar' },
      ] },
      { label: 'Community', bgColor: '#0b1f5c', textColor: '#ffffff', links: [
        { label: 'Discord Community', href: '/community', ariaLabel: 'Join the Discord community' },
        { label: 'Free Watchlist', href: '/free-watchlist', ariaLabel: 'Get the free watchlist' },
      ] },
      { label: 'Company', bgColor: '#0f1115', textColor: '#ffffff', links: [
        { label: 'Reviews', href: '/student-comments', ariaLabel: 'Read student reviews' },
        { label: 'Contact', href: '/contact', ariaLabel: 'Contact Bill Fanter' },
      ] },
    ];

    const mountCardNav = () => {
      const host = document.querySelector('.page-wrapper');
      if (!host || host.dataset.cardnavMounted === '1') return;
      host.dataset.cardnavMounted = '1';
      const mount = document.createElement('div');
      host.prepend(mount);
      try {
        createRoot(mount).render(React.createElement(CardNav, {
          logo: '/assets/664a5b263659c7265be280ad/664a67e5668f4d24bdabe38f_home%20images-10.webp',
          logoAlt: 'Bill Fanter',
          items: NAV_ITEMS,
          baseColor: '#ffffff',
          menuColor: '#0a0a0a',
          buttonBgColor: '#0a0a0a',
          buttonTextColor: '#ffffff',
          buttonLabel: 'Get the Masterclass',
          buttonHref: '/masterclass',
          loginLabel: 'Login',
          loginHref: 'https://members.billfanter.com/login',
          ease: 'power3.out',
        }));
      } catch (e) {
        console.error('[bf-cardnav] render error', e);
      }
    };

    /* React Bits AnimatedList — re-render the community benefits as animated
       rows. Content is read from the static .bf-benefit fallback already in the
       HTML, so the source of truth stays in markup and there's no duplication. */
    const mountBenefits = () => {
      const el = document.querySelector('[data-benefits-list]');
      if (!el || el.dataset.blMounted === '1') return;
      const items = [...el.querySelectorAll('.bf-benefit')].map((row) => ({
        num: row.querySelector('.bf-benefit__num')?.textContent ?? '',
        title: row.querySelector('.bf-benefit__title')?.textContent ?? '',
        body: row.querySelector('.bf-body')?.textContent ?? '',
      }));
      if (!items.length) return;
      el.dataset.blMounted = '1';
      el.innerHTML = '';
      try {
        createRoot(el).render(React.createElement(AnimatedList, { items }));
      } catch (e) {
        console.error('[bf-benefits] render error', e);
      }
    };

    const waitForDimensions = (el) =>
      new Promise((resolve) => {
        const check = () => {
          const r = el.getBoundingClientRect();
          if (r.width > 0 && r.height > 0) resolve();
          else requestAnimationFrame(check);
        };
        check();
      });

    const mountAll = async () => {
      const targets = document.querySelectorAll('[data-grainient]');
      if (!targets.length) return;
      for (const el of targets) {
        if (el.dataset.gMounted === '1') continue;
        el.dataset.gMounted = '1';
        await waitForDimensions(el);
        const props = {
          color1: el.dataset.color1 || '#FF8308',
          color2: el.dataset.color2 || '#EF4444',
          color3: el.dataset.color3 || '#6B3BD5',
          timeSpeed: 0.18,
          warpStrength: 1,
          warpFrequency: 4,
          warpAmplitude: 60,
          blendSoftness: 0.08,
          noiseScale: 1.6,
          grainAmount: 0.08,
          contrast: 1.4,
          saturation: 1.05,
          zoom: 0.85,
        };
        try {
          createRoot(el).render(React.createElement(Grainient, props));
        } catch (e) {
          console.error('[bf-grainient] render error for', el, e);
        }
      }
    };

    const runMounts = () => { mountAll(); mountBenefits(); mountCardNav(); mountGridDistortion(); };
    if (document.readyState === 'complete') runMounts();
    else window.addEventListener('load', runMounts);
  </script>
</BaseLayout>
