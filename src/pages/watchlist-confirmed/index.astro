---
import BaseLayout from '../../layouts/BaseLayout.astro';
import bodyHtml from './_body.html?raw';
import extraHeadHtml from './_head.html?raw';

const noindexTag = '<meta name="robots" content="noindex, nofollow" />';
---
<BaseLayout
  title={`You're In | Bill Fanter Weekly Watchlist`}
  description={`Your subscription is confirmed. Your first Weekly Watchlist arrives this Sunday.`}
  ogImage={`/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp`}
  wfPageId={`watchlist-confirmed`}
  extraHeadHtml={noindexTag + extraHeadHtml}
>
  <Fragment set:html={bodyHtml} />
</BaseLayout>
