---
// "How Can We Help?" — four-card help grid. Clean Astro, no Webflow classes.
const cards = [
  {
    href: '/masterclass',
    title: 'Join The Masterclass',
    body: 'Go from beginner to confident options trader in 6 live sessions with Bill.',
    icon: '<path d="M22 10 12 5 2 10l10 5z"/><path d="M6 12v5c0 1 3 3 6 3s6-2 6-3v-5"/><path d="M22 10v6"/>',
  },
  {
    href: '/community',
    title: 'Access The Community',
    body: 'Live Discord with real-time trade alerts and 1,000+ serious traders.',
    icon: '<path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-6 9a6 6 0 0 1 12 0"/><path d="M16 3.5a3 3 0 0 1 0 5.5M21 20a6 6 0 0 0-4.5-5.8"/>',
  },
  {
    href: '/webinar',
    title: 'Watch The Webinar',
    body: 'Free 60-min training on how I find, manage, and close winning trades.',
    icon: '<path d="M5 3v18l15-9z"/>',
  },
  {
    href: '/free-watchlist',
    title: 'Get The Watchlist',
    body: "A curated weekly list of stocks I'm watching, delivered every Sunday.",
    icon: '<path d="M3 17l6-6 4 4 8-8"/><path d="M14 7h7v7"/>',
  },
];
---
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">How Can We Help?</h2>
      <p class="bf-lead">Four ways to learn, grow, and trade alongside me.</p>
    </div>
    <div class="bf-help-grid">
      {cards.map((c) => (
        <a class="bf-help-card" href={c.href}>
          <div class="bf-help-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
          </div>
          <div class="bf-help-card__title">{c.title}</div>
          <p class="bf-body">{c.body}</p>
          <span class="bf-help-card__link">Learn more <svg class="bf-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
      ))}
    </div>
  </div>
</section>
