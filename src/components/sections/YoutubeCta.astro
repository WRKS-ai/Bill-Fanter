---
// YouTube CTA — full-bleed grainient card. Clean Astro (ported from /2026
// bf-darkcta). The grainient is mounted by BaseLayout's global [data-grainient]
// script.
---
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-darkcta">
      <div class="bf-grainient-mount is-full" data-grainient="youtube" data-color1="#FF8308" data-color2="#EF4444" data-color3="#6B3BD5"></div>
      <div class="bf-darkcta__grid">
        <div>
          <h2 class="bf-darkcta__h2">Explore trading insights on my YouTube channel</h2>
          <p class="bf-darkcta__lead">Subscribe now for regular updates and take your trading knowledge to the next level with engaging, educational content.</p>
          <div class="bf-darkcta__buttons">
            <a class="bf-darkcta__btn" href="https://www.youtube.com/@BillFanter" target="_blank" rel="noopener">
              <span class="bf-darkcta__btn-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span>
              Subscribe to my YouTube Channel
            </a>
          </div>
        </div>
        <div class="bf-darkcta__media" aria-hidden="true">
          <img class="bf-darkcta__media-overlay" src="/assets/664a5b263659c7265be280ad/665f4faf9e46e7d317a4e3d6_Group%201000010496.webp" alt="Bill Fanter YouTube channel" />
        </div>
      </div>
    </div>
  </div>
</section>
